@model IEnumerable<PropertyRentalManagement.Models.Message>

@{
    ViewData["Title"] = "Messages";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h1><i class="bi bi-chat-dots me-2"></i>Messages</h1>
    <a asp-action="Create" class="btn btn-primary"><i class="bi bi-plus-lg me-1"></i>New Message</a>
</div>

<div class="card shadow-sm border-0">
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover mb-0">
                <thead class="bg-light">
                    <tr>
                        <th class="ps-4">Status</th>
                        <th>From</th>
                        <th>To</th>
                        <th>Subject</th>
                        <th>Sent Date</th>
                        <th class="pe-4 text-end">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr class="@(item.IsRead ? "" : "fw-bold bg-light")">
                            <td class="ps-4">
                                @if (item.IsRead)
                                {
                                    <span class="badge bg-secondary">Read</span>
                                }
                                else
                                {
                                    <span class="badge bg-primary">New</span>
                                }
                            </td>
                            <td>@item.Sender?.Name</td>
                            <td>@item.Receiver?.Name</td>
                            <td>@item.Subject</td>
                            <td>@item.SentAt.ToString("g")</td>
                            <td class="pe-4 text-end">
                                <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-outline-info me-1"><i class="bi bi-eye"></i></a>
                                <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-outline-danger"><i class="bi bi-trash"></i></a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
