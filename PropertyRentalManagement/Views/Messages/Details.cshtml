@model PropertyRentalManagement.Models.Message

@{
    ViewData["Title"] = "Read Message";
}

<div class="row justify-content-center">
    <div class="col-md-8">
        <div class="card shadow border-0">
            <div class="card-header bg-primary text-white py-3">
                <h3 class="card-title mb-0"><i class="bi bi-envelope-open me-2"></i>Read Message</h3>
            </div>
            <div class="card-body p-4">
                <div class="d-flex justify-content-between align-items-center border-bottom pb-3 mb-4">
                    <div>
                        <div class="small text-muted">From:</div>
                        <div class="fw-bold fs-5 text-primary">@Model.Sender?.Name</div>
                    </div>
                    <div class="text-end">
                        <div class="small text-muted">Sent on:</div>
                        <div class="fw-bold">@Model.SentAt.ToString("MMM dd, yyyy HH:mm")</div>
                    </div>
                </div>

                <div class="mb-4">
                    <div class="small text-muted mb-1">Subject:</div>
                    <h4 class="fw-bold text-dark">@Model.Subject</h4>
                </div>

                <div class="bg-light p-4 rounded border mb-4" style="min-height: 150px; white-space: pre-wrap;">
                    @Model.Content
                </div>

                <div class="d-flex justify-content-between mt-4">
                    <div>
                        <a asp-action="Index" class="btn btn-outline-secondary px-4 me-2"><i class="bi bi-arrow-left me-1"></i>Back to Inbox</a>
                        @if (Model.SenderId != int.Parse(User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value ?? "0"))
                        {
                            <a asp-action="Create" asp-route-receiverId="@Model.SenderId" asp-route-subject="@Model.Subject" class="btn btn-primary px-4">
                                <i class="bi bi-reply me-1"></i>Reply
                            </a> @* // FIXED: Reply to tenant messages *@
                        }
                    </div>
                    <a asp-action="Delete" asp-route-id="@Model.Id" class="btn btn-outline-danger px-4">Delete Message</a>
                </div>
            </div>
        </div>
    </div>
</div>
