@model PropertyRentalManagement.Models.Message

@{
    ViewData["Title"] = "Delete Message";
}

<div class="row justify-content-center">
    <div class="col-md-6">
        <div class="card shadow border-0">
            <div class="card-header bg-danger text-white py-3">
                <h3 class="card-title mb-0"><i class="bi bi-trash me-2"></i>Delete Message</h3>
            </div>
            <div class="card-body p-4 text-center">
                <i class="bi bi-envelope-x text-danger display-4 mb-3"></i>
                <h4>Delete this message?</h4>
                <p class="text-muted mb-4">Confirming this will permanently remove the message <strong>"@Model.Subject"</strong> from your history.</p>
                
                <div class="bg-light p-3 rounded mb-4 text-start small">
                    <div><strong>From:</strong> @Model.Sender?.Name</div>
                    <div><strong>Date:</strong> @Model.SentAt.ToString("g")</div>
                </div>

                <form asp-action="Delete" method="post">
                    @Html.AntiForgeryToken()
                    <input type="hidden" asp-for="Id" />
                    <div class="d-flex justify-content-center">
                        <a asp-action="Index" class="btn btn-outline-secondary px-4 me-2">Cancel</a>
                        <button type="submit" class="btn btn-danger px-4">Delete Permanently</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>
