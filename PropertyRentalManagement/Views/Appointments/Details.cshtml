@model PropertyRentalManagement.Models.Appointment

@{
    ViewData["Title"] = "Appointment Details";
}

<h1>Appointment Details</h1>
<hr />
<div class="card shadow-sm mb-4">
    <div class="card-body">
        <dl class="row">
            <dt class="col-sm-3">Apartment</dt>
            <dd class="col-sm-9">@Html.DisplayFor(model => model.Apartment!.AptNumber)</dd>

            <dt class="col-sm-3">User</dt>
            <dd class="col-sm-9">@Html.DisplayFor(model => model.User!.Name)</dd>

            <dt class="col-sm-3">Manager</dt>
            <dd class="col-sm-9">@Html.DisplayFor(model => model.Manager!.Name)</dd>

            <dt class="col-sm-3">@Html.DisplayNameFor(model => model.AppointmentDate)</dt>
            <dd class="col-sm-9">@Model.AppointmentDate.ToString("g")</dd>

            <dt class="col-sm-3">@Html.DisplayNameFor(model => model.Status)</dt>
            <dd class="col-sm-9">
                @if(Model.Status == "Scheduled") { <span class="badge bg-primary">@Model.Status</span> }
                else if(Model.Status == "Completed") { <span class="badge bg-success">@Model.Status</span> }
                else { <span class="badge bg-secondary">@Model.Status</span> }
            </dd>

            <dt class="col-sm-3">@Html.DisplayNameFor(model => model.Notes)</dt>
            <dd class="col-sm-9">@Html.DisplayFor(model => model.Notes)</dd>
        </dl>
    </div>
</div>
<div>
    <a asp-action="Edit" asp-route-id="@Model?.Id" class="btn btn-primary">Edit</a>
    <a asp-action="Index" class="btn btn-secondary">Back to List</a>
</div>
