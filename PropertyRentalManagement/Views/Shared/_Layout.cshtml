<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Property Rental Management</title>
    <!-- Use standard Bootstrap 5 Theme -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
</head>
<body class="bg-light">
    <header>
        <nav class="navbar navbar-expand-lg" style="background-color: #2c3e50;">
            <div class="container">
                <a class="navbar-brand text-white fw-bold" asp-controller="Home" asp-action="Index">
                    Property Rental System
                </a>
                <button class="navbar-toggler text-white" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse" aria-controls="navbarSupportedContent"
                        aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon" style="filter: invert(1);"></span>
                </button>
                <div class="navbar-collapse collapse d-sm-inline-flex justify-content-between">
                    <div class="navbar-nav ms-auto">
                        @if (User.Identity?.IsAuthenticated == true)
                        {
                            @if (User.IsInRole(UserRoles.Owner) || User.IsInRole(UserRoles.Manager) || User.IsInRole(UserRoles.Tenant))
                            {
                                <a class="nav-link text-white" asp-controller="Buildings" asp-action="Index">Buildings</a>
                            }
                            <a class="nav-link text-white" asp-controller="Apartments" asp-action="Index">Apartments</a>
                            @if (User.IsInRole(UserRoles.Owner))
                            {
                                <a class="nav-link text-white" asp-controller="Users" asp-action="Index">Users</a>
                            }
                            <a class="nav-link text-white" asp-controller="Appointments" asp-action="Index">Appointments</a>
                            <a class="nav-link text-white border-start ms-2 ps-3" asp-controller="Messages" asp-action="Index"><i class="bi bi-chat-dots me-1"></i>Messages</a>
                            @if (User.IsInRole(UserRoles.Owner) || User.IsInRole(UserRoles.Manager))
                            {
                                <a class="nav-link text-white ms-2" asp-controller="Events" asp-action="Index"><i class="bi bi-exclamation-triangle me-1"></i>Events</a>
                            }
                            <span class="nav-link text-white-50 ms-2">@User.Identity.Name (@User.FindFirst(System.Security.Claims.ClaimTypes.Role)?.Value)</span>
                            <form asp-controller="Account" asp-action="Logout" method="post" class="ms-2 d-inline">
                                @Html.AntiForgeryToken()
                                <button type="submit" class="btn btn-sm btn-outline-light">Logout</button>
                            </form>
                        }
                        else
                        {
                            <a class="nav-link text-white" asp-controller="Account" asp-action="Login">Login</a>
                            <a class="nav-link text-white" asp-controller="Account" asp-action="Register">Register</a>
                        }
                    </div>
                </div>
            </div>
        </nav>
    </header>
    
    <div class="container my-5" style="min-height: 80vh;">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <footer class="footer text-muted bg-dark py-4 mt-auto">
        <div class="container text-center">
            &copy; 2026 - Designed for Final Presentation - <a asp-area="" asp-controller="Home" asp-action="Privacy" class="text-info">Privacy Policy</a>
        </div>
    </footer>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
