@model PropertyRentalManagement.Models.ViewModels.DashboardViewModel
@{
    ViewData["Title"] = "Dashboard";
}

<div class="text-center mb-5">
    <h1 class="display-4 fw-bold text-dark">Property Rental Management</h1>
    <p class="lead text-muted">Welcome to your dashboard overview.</p>
</div>

<div class="row g-4">
    <div class="col-md-3">
        <div class="card text-white bg-primary shadow-sm h-100">
            <div class="card-body d-flex flex-column justify-content-center align-items-center">
                <i class="fa-solid fa-building fa-3x mb-3"></i>
                <h5 class="card-title">Buildings</h5>
                <h2 class="fw-bold">@Model.TotalBuildings</h2>
            </div>
            <div class="card-footer bg-transparent border-top-0 d-grid">
                <a asp-controller="Buildings" asp-action="Index" class="btn btn-light btn-sm text-primary">View Buildings</a>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card text-white bg-success shadow-sm h-100">
            <div class="card-body d-flex flex-column justify-content-center align-items-center">
                <i class="fa-solid fa-door-open fa-3x mb-3"></i>
                <h5 class="card-title">Apartments</h5>
                <h2 class="fw-bold">@Model.TotalApartments</h2>
            </div>
            <div class="card-footer bg-transparent border-top-0 d-grid">
                <a asp-controller="Apartments" asp-action="Index" class="btn btn-light btn-sm text-success">View Apartments</a>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card text-dark bg-warning shadow-sm h-100">
            <div class="card-body d-flex flex-column justify-content-center align-items-center">
                <i class="fa-solid fa-users fa-3x mb-3"></i>
                <h5 class="card-title">Users</h5>
                <h2 class="fw-bold">@Model.TotalUsers</h2>
            </div>
            <div class="card-footer bg-transparent border-top-0 d-grid">
                <a asp-controller="Users" asp-action="Index" class="btn btn-light btn-sm text-warning text-dark font-weight-bold">View Users</a>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card text-white bg-danger shadow-sm h-100">
            <div class="card-body d-flex flex-column justify-content-center align-items-center">
                <i class="fa-solid fa-calendar-check fa-3x mb-3"></i>
                <h5 class="card-title">Appointments</h5>
                <h2 class="fw-bold">@Model.TotalAppointments</h2>
            </div>
            <div class="card-footer bg-transparent border-top-0 d-grid">
                <a asp-controller="Appointments" asp-action="Index" class="btn btn-light btn-sm text-danger">View Appointments</a>
            </div>
        </div>
    </div>
</div>
