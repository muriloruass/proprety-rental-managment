@model IEnumerable<PropertyRentalManagement.Models.User>

@{
    ViewData["Title"] = "Users";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h1>Users</h1>
    <a asp-action="Create" class="btn btn-primary"><i class="fa-solid fa-plus"></i> Add New</a>
</div>

<form method="get" class="row g-2 mb-3">
    @* // FIXED: Create/Update/Delete/Search/List property manager accounts *@
    <div class="col-md-6">
        <input type="text" name="search" value="@ViewBag.Search" class="form-control" placeholder="Search by name or email" />
    </div>
    <div class="col-md-3">
        <select name="role" class="form-select">
            <option value="">All roles</option>
            <option value="Manager" selected="@(ViewBag.Role == "Manager" ? "selected" : null)">Manager</option>
            <option value="Tenant" selected="@(ViewBag.Role == "Tenant" ? "selected" : null)">Tenant</option>
            <option value="Owner" selected="@(ViewBag.Role == "Owner" ? "selected" : null)">Owner</option>
        </select>
    </div>
    <div class="col-md-3 d-flex gap-2">
        <button type="submit" class="btn btn-outline-primary">Search</button>
        <a asp-action="Index" class="btn btn-outline-secondary">Clear</a>
    </div>
</form>

@if (TempData["Error"] != null)
{
    <div class="alert alert-danger">@TempData["Error"]</div>
}

<table class="table table-striped table-hover shadow-sm">
    <thead class="table-dark">
        <tr>
            <th>@Html.DisplayNameFor(model => model.Name)</th>
            <th>@Html.DisplayNameFor(model => model.Email)</th>
            <th>@Html.DisplayNameFor(model => model.Role)</th>
            <th>Actions</th>
        </tr>
    </thead>
    <tbody>
@foreach (var item in Model) {
        <tr>
            <td>@Html.DisplayFor(modelItem => item.Name)</td>
            <td>@Html.DisplayFor(modelItem => item.Email)</td>
            <td>@Html.DisplayFor(modelItem => item.Role)</td>
            <td>
                <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-primary">Edit</a> |
                <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-info text-white">Details</a> |
                <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-danger">Delete</a>
            </td>
        </tr>
}
    </tbody>
</table>
