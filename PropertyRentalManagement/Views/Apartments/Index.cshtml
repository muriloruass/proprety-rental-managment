@model IEnumerable<PropertyRentalManagement.Models.Apartment>

@{
    ViewData["Title"] = "Apartments";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h1>Apartments</h1>
    <a asp-action="Create" class="btn btn-primary"><i class="fa-solid fa-plus"></i> Add New</a>
</div>

<form method="get" class="row g-3 mb-4 p-3 bg-white shadow-sm rounded">
    @* // FIXED: Search/view apartments *@
    <div class="col-md-4">
        <label class="form-label small text-muted">Keyword</label>
        <input type="text" name="search" value="@ViewBag.Search" class="form-control" placeholder="Apt # or Building" />
    </div>
    <div class="col-md-2">
        <label class="form-label small text-muted">Status</label>
        <select name="status" class="form-select">
            <option value="">All</option>
            <option value="Available" selected="@(ViewBag.Status == "Available" ? "selected" : null)">Available</option>
            <option value="Rented" selected="@(ViewBag.Status == "Rented" ? "selected" : null)">Rented</option>
            <option value="Under Maintenance" selected="@(ViewBag.Status == "Under Maintenance" ? "selected" : null)">Maintenance</option>
        </select>
    </div>
    <div class="col-md-2">
        <label class="form-label small text-muted">Min Price</label>
        <input type="number" name="minPrice" value="@ViewBag.MinPrice" class="form-control" placeholder="0" />
    </div>
    <div class="col-md-2">
        <label class="form-label small text-muted">Max Price</label>
        <input type="number" name="maxPrice" value="@ViewBag.MaxPrice" class="form-control" placeholder="10000" />
    </div>
    <div class="col-md-1">
        <label class="form-label small text-muted">Rooms</label>
        <input type="number" name="rooms" value="@ViewBag.Rooms" class="form-control" placeholder="1" />
    </div>
    <div class="col-md-1 d-flex align-items-end gap-1">
        <button type="submit" class="btn btn-primary w-100" title="Search"><i class="fa-solid fa-magnifying-glass"></i></button>
        <a asp-action="Index" class="btn btn-secondary w-100" title="Reset"><i class="fa-solid fa-rotate-left"></i></a>
    </div>
</form>

<table class="table table-striped table-hover shadow-sm">
    <thead class="table-dark">
        <tr>
            <th>@Html.DisplayNameFor(model => model.AptNumber)</th>
            <th>Building</th>
            <th>@Html.DisplayNameFor(model => model.Rooms)</th>
            <th>@Html.DisplayNameFor(model => model.Bathrooms)</th>
            <th>@Html.DisplayNameFor(model => model.Rent)</th>
            <th>@Html.DisplayNameFor(model => model.Status)</th>
            <th>Actions</th>
        </tr>
    </thead>
    <tbody>
@foreach (var item in Model) {
        <tr>
            <td>@Html.DisplayFor(modelItem => item.AptNumber)</td>
            <td>@Html.DisplayFor(modelItem => item.Building.Name)</td>
            <td>@Html.DisplayFor(modelItem => item.Rooms)</td>
            <td>@Html.DisplayFor(modelItem => item.Bathrooms)</td>
            <td>@Html.DisplayFor(modelItem => item.Rent)</td>
            <td>
                @if(item.Status == "Available") { <span class="badge bg-success">@item.Status</span> }
                else if(item.Status == "Under Maintenance") { <span class="badge bg-warning text-dark">@item.Status</span> }
                else { <span class="badge bg-danger">@item.Status</span> }
            </td>
            <td>
                <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-primary">Edit</a> |
                <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-info text-white">Details</a> |
                <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-danger">Delete</a>
            </td>
        </tr>
}
    </tbody>
</table>
