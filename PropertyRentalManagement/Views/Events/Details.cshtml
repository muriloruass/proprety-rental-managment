@model PropertyRentalManagement.Models.Event

@{
    ViewData["Title"] = "Event Details";
}

<div class="row justify-content-center">
    <div class="col-md-8">
        <div class="card shadow border-0">
            <div class="card-header bg-info text-white py-3">
                <h3 class="card-title mb-0"><i class="bi bi-info-circle me-2"></i>Event Details</h3>
            </div>
            <div class="card-body p-4">
                <div class="row mb-4">
                    <div class="col-sm-3 fw-bold text-muted">Title</div>
                    <div class="col-sm-9 h5">@Model.Title</div>
                </div>
                <div class="row mb-4">
                    <div class="col-sm-3 fw-bold text-muted">Severity</div>
                    <div class="col-sm-9">
                        <span class="badge @(Model.Severity == "High" ? "bg-danger" : Model.Severity == "Medium" ? "bg-warning text-dark" : "bg-info")">
                            @Model.Severity Priority
                        </span>
                    </div>
                </div>
                <div class="row mb-4">
                    <div class="col-sm-3 fw-bold text-muted">Date</div>
                    <div class="col-sm-9">@Model.EventDate.ToString("f")</div>
                </div>
                <div class="row mb-4">
                    <div class="col-sm-3 fw-bold text-muted">Apartment</div>
                    <div class="col-sm-9">
                        @(Model.Apartment != null ? $"Apt {Model.Apartment.AptNumber} - {Model.Apartment.Building?.Name}" : "General / Building Level")
                    </div>
                </div>
                <div class="row mb-4">
                    <div class="col-sm-3 fw-bold text-muted">Reported By</div>
                    <div class="col-sm-9">@Model.ReportedBy?.Name</div>
                </div>
                <div class="row mb-4">
                    <div class="col-sm-3 fw-bold text-muted">Description</div>
                    <div class="col-sm-9 bg-light p-3 rounded">
                        @Model.Description
                    </div>
                </div>

                <div class="d-flex justify-content-between mt-4">
                    <a asp-action="Index" class="btn btn-outline-secondary px-4"><i class="bi bi-arrow-left me-1"></i>Back to List</a>
                    <div>
                        <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-primary px-4 me-2">Edit</a>
                        <a asp-action="Delete" asp-route-id="@Model.Id" class="btn btn-danger px-4">Delete</a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
