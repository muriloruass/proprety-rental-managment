@model PropertyRentalManagement.Models.Event

@{
    ViewData["Title"] = "Report Event";
}

<div class="row justify-content-center">
    <div class="col-md-8">
        <div class="card shadow border-0">
            <div class="card-header bg-warning text-dark py-3">
                <h3 class="card-title mb-0"><i class="bi bi-exclamation-triangle me-2"></i>Report New Event/Issue</h3>
            </div>
            <div class="card-body p-4">
                <form asp-action="Create" method="post">
                    @Html.AntiForgeryToken()
                    <div asp-validation-summary="ModelOnly" class="text-danger"></div>
                    
                    <div class="mb-3">
                        <label asp-for="Title" class="form-label fw-bold">Event Title</label>
                        <input asp-for="Title" class="form-control" placeholder="Brief summary of the event" />
                        <span asp-validation-for="Title" class="text-danger"></span>
                    </div>

                    <div class="row mb-3">
                        <div class="col-md-6">
                            <label asp-for="Severity" class="form-label fw-bold">Severity Level</label>
                            <select asp-for="Severity" class="form-select">
                                <option value="Low">Low - Informational</option>
                                <option value="Medium">Medium - Requires Attention</option>
                                <option value="High">High - Urgent / Emergency</option>
                            </select>
                            <span asp-validation-for="Severity" class="text-danger"></span>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="EventDate" class="form-label fw-bold">Date of Event</label>
                            <input asp-for="EventDate" class="form-control" type="datetime-local" value="@DateTime.Now.ToString("yyyy-MM-ddTHH:mm")" />
                            <span asp-validation-for="EventDate" class="text-danger"></span>
                        </div>
                    </div>

                    <div class="mb-3">
                        <label asp-for="ApartmentId" class="form-label fw-bold">Related Apartment</label>
                        <select asp-for="ApartmentId" class="form-select" asp-items="ViewBag.ApartmentId">
                            <option value="">-- General / Building Level --</option>
                        </select>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Description" class="form-label fw-bold">Detailed Description</label>
                        <textarea asp-for="Description" class="form-control" rows="4" placeholder="Describe what happened and any actions taken..."></textarea>
                        <span asp-validation-for="Description" class="text-danger"></span>
                    </div>

                    <div class="d-flex justify-content-between mt-4">
                        <a asp-action="Index" class="btn btn-outline-secondary px-4"><i class="bi bi-arrow-left me-1"></i>Back to Events</a>
                        <button type="submit" class="btn btn-warning px-5"><i class="bi bi-megaphone-fill me-1"></i>Submit Report</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @* // FIXED: Client-side JS validation *@
    <partial name="_ValidationScriptsPartial" />
}
